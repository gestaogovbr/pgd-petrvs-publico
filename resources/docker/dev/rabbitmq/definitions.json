{
  "vhosts": [
    { "name": "/" }
  ],
  "users": [
    {
      "name": "petrvs",
      "password": "petrvs",
      "tags": "administrator"
    }
  ],
  "permissions": [
    {
      "user": "petrvs",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    }
  ],
  "queues": [
    {
      "name": "pgd_queue",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "pgd_queue_delay",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-message-ttl": 300000,
        "x-dead-letter-exchange": "",
        "x-dead-letter-routing-key": "pgd_queue"
      }
    }
  ]
}